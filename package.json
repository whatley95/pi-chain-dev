{
  "name": "pi-chain-dev",
  "version": "0.1.0",
  "description": "Two-stage development fork for Pi coding agent. Exploration with cheap model, synthesis with powerful model.",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src",
    "scripts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "pi",
    "fork",
    "dev",
    "two-stage",
    "delegation",
    "pi-package"
  ],
  "scripts": {
    "build": "node scripts/update-build-date.cjs && tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "test:watch": "tsx --test --watch test/**/*.test.ts",
    "lint": "eslint src test",
    "setup-hook": "node scripts/install-hook.cjs"
  },
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-agent-core": ">=0.75.0",
    "@earendil-works/pi-coding-agent": ">=0.75.0",
    "@sinclair/typebox": ">=0.34.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
